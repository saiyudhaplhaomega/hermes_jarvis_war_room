{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://jarvis.local/schemas/release-report.json",
  "title": "War Room Phase Release Report",
  "description": "Evidence required to claim a phase is releasable.",
  "type": "object",
  "additionalProperties": true,
  "required": ["phase", "timestamp", "commands", "gates", "artifacts"],
  "properties": {
    "phase": {"type": "string", "minLength": 1},
    "timestamp": {"type": "string", "format": "date-time"},
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "command", "exit_code"],
        "properties": {
          "name": {"type": "string"},
          "command": {"type": "string"},
          "exit_code": {"type": "integer"},
          "output_snippet": {"type": "string"}
        }
      }
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "passed"],
        "properties": {
          "name": {"type": "string"},
          "passed": {"type": "boolean"}
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path": {"type": "string"},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
        }
      }
    }
  }
}
