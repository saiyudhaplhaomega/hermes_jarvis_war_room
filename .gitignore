# Runtime secrets/state
state/
*.env
.env
.env.*
!.env.example

# Python local environment/cache
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Node dependencies/cache
frontend-react/node_modules/
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-store/

# Logs/PIDs
*.log
*.pid
*.sock

# Local/temp backups that may contain injected runtime tokens
/tmp/
*.pre-recovery-*
*.tmp
*.bak

# OS/editor
.DS_Store
.vscode/
.idea/

# Keep built React dist committed intentionally for recovery/deployment snapshot.
# frontend-react/dist/ is NOT ignored.
